{
  "name": "mod-emotor",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "电改模拟工具 - 电动车姿态与改装参数模拟网站",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "sync:accessories": "node scripts/download-motomate-accessories.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "test:security": "node --test tests/security-check.test.mjs",
    "security": "node scripts/security-check.mjs && npm audit --audit-level=high",
    "check": "npm run security && npm test && npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    },
    "minimatch@10.2.4": {
      "brace-expansion": "5.0.7"
    },
    "js-yaml": "4.3.0",
    "postcss": "8.5.19"
  }
}
